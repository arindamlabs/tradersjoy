# Copy this file to .env and fill in real values. .env is gitignored.

# Alpaca paper-trading credentials
# Get these from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Use the paper-trading endpoint until we explicitly graduate to live.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Local SQLite store for bars, trades, positions, equity curve.
DATABASE_URL=sqlite:///data/tradersjoy.sqlite
